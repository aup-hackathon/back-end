NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://app:secret@app-db:5432/appdb
NATS_URL=nats://nats:4222
NATS_STREAM_NAME=FLOWFORGE
JWT_ACCESS_SECRET=replace-me-access-secret-min-32-characters
JWT_REFRESH_SECRET=replace-me-refresh-secret-min-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_EXPORTS=exports
OLLAMA_URL=http://ollama:11434
FASTAPI_HEALTH_URL=http://fastapi:8000/health
ELSA_HEALTH_URL=http://elsa-server:8080/health
CORS_ORIGIN=http://localhost:3001
DEV_BYPASS_AUTH=false
THROTTLE_TTL=60
THROTTLE_LIMIT=120
LOG_LEVEL=info
