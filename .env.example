NODE_ENV=development
PORT=3000

APP_DB_NAME=appdb
APP_DB_USER=app
APP_DB_PASSWORD=change-me-app-db-password
APP_DB_PORT=5432
DATABASE_URL=postgres://app:change-me-app-db-password@localhost:5432/appdb
MIGRATION_DATABASE_URL=postgres://app:change-me-app-db-password@localhost:5432/appdb

ELSA_DB_NAME=elsadb
ELSA_DB_USER=elsa
ELSA_DB_PASSWORD=change-me-elsa-db-password
ELSA_DB_PORT=5433

NATS_URL=nats://localhost:4222
NATS_STREAM_NAME=FLOWFORGE
NATS_PORT=4222
NATS_MONITOR_PORT=8222

JWT_ACCESS_SECRET=replace-me-with-at-least-32-chars-access
JWT_REFRESH_SECRET=replace-me-with-at-least-32-chars-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=change-me-minio-password
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_EXPORTS=exports

OLLAMA_URL=http://localhost:11434
OLLAMA_PORT=11434
OLLAMA_LLM_MODEL=mistral:7b-instruct
OLLAMA_EMBED_MODEL=nomic-embed-text

FASTAPI_HEALTH_URL=http://localhost:8000/health
FASTAPI_PORT=8000
ELSA_HEALTH_URL=http://localhost:5000/health
ELSA_PORT=5000
ELSA_SERVER_IMAGE=elsaworkflows/elsa-server-v3-5:latest

NESTJS_CONTEXT=.
NESTJS_DOCKERFILE=Dockerfile
NESTJS_PORT=3000
FASTAPI_CONTEXT=./infra/placeholders/fastapi
NEXTJS_CONTEXT=./infra/placeholders/nextjs
NEXTJS_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000
NEXT_PUBLIC_ELSA_URL=http://localhost:5000

CORS_ORIGIN=http://localhost:3001
DEV_BYPASS_AUTH=false
THROTTLE_TTL=60
THROTTLE_LIMIT=120
LOG_LEVEL=info
